{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "gatherpress/venue-map",
	"version": "1.0.0",
	"title": "Venue Map",
	"category": "gatherpress",
	"icon": "location-alt",
	"description": "Display a map for the venue location.",
	"parent": ["gatherpress/venue"],
	"usesContext": ["postId", "postType", "queryId"],
	"attributes": {
		"zoom": {
			"type": "number",
			"default": 16
		},
		"type": {
			"type": "string",
			"default": "roadmap"
		},
		"height": {
			"type": "number"
		},
		"width": {
			"type": "number"
		},
		"aspectRatio": {
			"type": "string",
			"default": "2/1"
		},
		"scale": {
			"type": "string",
			"enum": ["cover", "contain", "fill"],
			"default": "cover"
		},
		"renderMode": {
			"type": "string",
			"default": "interactive"
		},
		"href": {
			"type": "string",
			"default": ""
		},
		"linkDestination": {
			"type": "string",
			"default": "none"
		},
		"linkTarget": {
			"type": "string",
			"default": ""
		},
		"rel": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"align": ["left", "center", "right", "wide", "full"],
		"html": false,
		"dimensions": {
			"height": true,
			"width": true,
			"__experimentalSkipSerialization": true,
			"__experimentalDefaultControls": {
				"height": false,
				"width": false
			}
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalDefaultControls": {
				"margin": false,
				"padding": false
			}
		},
		"__experimentalBorder": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true,
			"__experimentalDefaultControls": {
				"color": true,
				"radius": true,
				"style": true,
				"width": true
			}
		},
		"shadow": true
	},
	"textdomain": "gatherpress",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"viewScript": "file:./view.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
