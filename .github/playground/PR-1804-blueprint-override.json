{
	"$schema": "https://gatherpress.org/playground-preview/pr-override-schema.json",
	"siteOptions": {
		"timezone_string": "Europe/Amsterdam",
        "permalink_structure": "/%postname%/",
        "users_can_register": 0
	},
	"features": {
		"networking": true
	},
	"prependSteps": [
        {
            "step": "defineWpConfigConsts",
            "consts": {
                "WP_ENVIRONMENT_TYPE": "staging"
            }
        },
        {
            "step": "installPlugin",
            "pluginData": { "resource": "wordpress.org/plugins", "slug": "query-monitor" },
            "options": { "activate": true }
        }
	],
    "appendSteps": [
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "url",
				"url": "https://github.com/GatherPress/gatherpress/releases/download/0.34.0-alpha.2/gatherpress.0.34.0-alpha.2.zip"
			},
            "options": {
                "activate": true
            }
		}
    ]
}